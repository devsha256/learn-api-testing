<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%-5p %d [%t] [%c] - %m%n"/>
        </Console>
    </Appenders>

    <Loggers>

        <!-- Keep default Mule runtime noise at WARN -->
        <AsyncRoot level="WARN">
            <AppenderRef ref="Console"/>
        </AsyncRoot>

        <!-- ============================================================ -->
        <!-- LEAK DETECTION LOGGERS                                        -->
        <!-- If any of these print at DEBUG during MUnit, the mock failed  -->
        <!-- ============================================================ -->

        <!-- HTTP: logs the final resolved URI for every real outbound call -->
        <AsyncLogger name="org.mule.extension.http.internal.request.HttpRequestOperations"
                     level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>

        <!-- JMS: logs destination and message details on real publish/consume -->
        <AsyncLogger name="org.mule.extensions.jms.internal.operation.JmsPublish"
                     level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>

        <AsyncLogger name="org.mule.extensions.jms.internal.operation.JmsConsume"
                     level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>

        <!-- DB: logs SQL statements on every real execution -->
        <AsyncLogger name="org.mule.extension.db"
                     level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>

        <!-- SFTP: logs file path and operation on every real transfer -->
        <AsyncLogger name="org.mule.extension.sftp"
                     level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>

        <!-- VM Connector -->
        <AsyncLogger name="org.mule.extensions.vm"
                     level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>

        <!-- Object Store -->
        <AsyncLogger name="org.mule.extension.objectstore"
                     level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>

    </Loggers>
</Configuration>
