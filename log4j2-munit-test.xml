<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <!-- Ensure immediateFlush is handled by the console appender -->
            <PatternLayout pattern="%-5p %d [%t] [%c] - %m%n"/>
        </Console>
    </Appenders>

    <Loggers>
        <AsyncRoot level="WARN">
            <AppenderRef ref="Console"/>
        </AsyncRoot>

        <!-- ============================================================ -->
        <!-- FIXED LEAK DETECTION LOGGERS                                 -->
        <!-- ============================================================ -->

        <!-- HTTP: Targets both the extension and the actual service client -->
        <AsyncLogger name="org.mule.service.http.impl.service.client" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>
        <AsyncLogger name="org.mule.extension.http.internal.request" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>

        <!-- JMS: FIXED - Moved to jms.commons where Mule 4 actually executes -->
        <AsyncLogger name="org.mule.jms.commons.internal.operation" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>
        <AsyncLogger name="org.mule.extensions.jms" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>

        <!-- DB: Standard database extension logging -->
        <AsyncLogger name="org.mule.extension.db" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>

        <!-- SFTP/FTP: Covers both file-based connectors -->
        <AsyncLogger name="org.mule.extension.sftp" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>
        <AsyncLogger name="org.mule.extension.file" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>

        <!-- SALESFORCE: SDK and Transport level -->
        <AsyncLogger name="org.mule.extension.salesforce" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>
        <AsyncLogger name="com.sforce.ws.transport" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>

        <!-- SOCKETS: Raw TCP/UDP connections -->
        <AsyncLogger name="org.mule.extension.sockets" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>

        <!-- VM & OBJECT STORE -->
        <AsyncLogger name="org.mule.extensions.vm" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>
        <AsyncLogger name="org.mule.extension.objectstore" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </AsyncLogger>

    </Loggers>
</Configuration>
