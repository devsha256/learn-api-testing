##############################################################################
# 10. CATCH-ALL — MULE SDK OPERATION PROCESSOR (disabled by default)
# Class: org.mule.runtime.module.extension.internal.runtime.operation
#          .OperationMessageProcessor
# MUnit mock-when intercepts here. If doProcess is reached during a test,
# the operation was NOT mocked. HIGH NOISE — uncomment only for diagnosis.
##############################################################################

# RULE MUNIT_LEAK :: CATCH-ALL OperationMessageProcessor.doProcess
# CLASS org.mule.runtime.module.extension.internal.runtime.operation.OperationMessageProcessor
# METHOD doProcess
# AT ENTRY
# IF true
# DO
#   traceln("[MUNIT_LEAK][CATCH-ALL] Unmocked extension operation: " +
#     $0.getClass().getName() +
#     " Thread=" + Thread.currentThread().getName())
# ENDRULE
