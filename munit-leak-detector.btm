IF true
DO
  traceln("[MUNIT_LEAK][SFTP-JCRAFT-READ] Real SFTP get via JSch detected." +
    " Thread=" + Thread.currentThread().getName())
ENDRULE

# Apache Mina transport layer — connector >= 2.0.x
RULE MUNIT_LEAK :: SFTP write via Mina AbstractSftpClient.write
CLASS org.apache.sshd.sftp.client.impl.AbstractSftpClient
METHOD write
AT ENTRY
IF true
DO
  traceln("[MUNIT_LEAK][SFTP-MINA-WRITE] Real SFTP write via Apache Mina SSHD detected." +
