RULE Socket Connect
CLASS java.net.Socket
METHOD connect
AT ENTRY
DO traceln("[SOCKET] " + $1);
ENDRULE

RULE Netty Bootstrap Connect
CLASS io.netty.bootstrap.Bootstrap
METHOD connect
AT ENTRY
DO traceln("[NETTY] " + $1);
ENDRULE

RULE NIO Socket Connect
CLASS sun.nio.ch.SocketChannelImpl
METHOD connect
AT ENTRY
DO traceln("[NIO] " + $1);
ENDRULE

RULE SSL Handshake
CLASS javax.net.ssl.SSLSocket
METHOD startHandshake
AT ENTRY
DO traceln("[SSL]");
ENDRULE
