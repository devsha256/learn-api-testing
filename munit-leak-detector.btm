##############################################################################
# 3. DATABASE CONNECTOR
# Intercepted at JDBC interface level — stable across ALL DB connector
# versions and ALL drivers. java.sql interfaces are bootstrap-loaded and
# always visible to Byteman without classloader issues.
##############################################################################

RULE MUNIT_LEAK :: DB via PreparedStatement.execute
INTERFACE java.sql.PreparedStatement
METHOD execute()
AT ENTRY
IF true
DO
  traceln("[MUNIT_LEAK][DB] Real DB PreparedStatement.execute() - mock NOT applied." +
    " ImplClass=" + $0.getClass().getName() +
    " Thread=" + Thread.currentThread().getName())
ENDRULE

RULE MUNIT_LEAK :: DB via PreparedStatement.executeQuery
INTERFACE java.sql.PreparedStatement
METHOD executeQuery()
AT ENTRY
IF true
DO
  traceln("[MUNIT_LEAK][DB] Real DB PreparedStatement.executeQuery() detected." +
    " ImplClass=" + $0.getClass().getName() +
    " Thread=" + Thread.currentThread().getName())
ENDRULE

RULE MUNIT_LEAK :: DB via PreparedStatement.executeUpdate
