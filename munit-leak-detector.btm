##############################################################################
# MuleSoft MUnit Outbound Leak Detection Rules
#
# ACTIVATION:
#   set JAVA_TOOL_OPTIONS=-javaagent:C:\byteman\byteman.jar=^
#     script:C:\rules\munit-leak-detect.btm,^
#     boot:C:\byteman\byteman.jar,^
#     listener:true ^
#     -Dorg.jboss.byteman.transform.all=true
#
# SEARCH IN LOGS:  grep "MUNIT_LEAK" surefire-reports/*.txt
##############################################################################


##############################################################################
# 1. HTTP CONNECTOR
# Class:  org.mule.service.http.impl.service.client.GrizzlyHttpClient
# Source: github.com/mulesoft/mule-http-service (master, verified)
# doSendAsync is called for ALL outbound HTTP regardless of method, auth,
# or connection pool reuse. Bypasses Socket.connect entirely.
##############################################################################

RULE MUNIT_LEAK :: HTTP outbound via GrizzlyHttpClient.doSendAsync
CLASS org.mule.service.http.impl.service.client.GrizzlyHttpClient
METHOD doSendAsync
AT ENTRY
IF true
DO
  traceln("[MUNIT_LEAK][HTTP] Real HTTP request - mock NOT applied." +
    " URI=" + $1.getUri().toString() +
    " Method=" + $1.getMethod() +
    " Thread=" + Thread.currentThread().getName());
  traceln("[MUNIT_LEAK][HTTP] Stack=" +
    java.util.Arrays.toString(Thread.currentThread().getStackTrace()))
ENDRULE


##############################################################################
# Belt-and-suspenders at connector operation layer (fires before Grizzly).
# Class:  org.mule.extension.http.internal.request.HttpRequestOperations
# Source: confirmed via HTTP Connector release notes MULE-16295 (verified)
##############################################################################

RULE MUNIT_LEAK :: HTTP outbound via HttpRequestOperations.request
CLASS org.mule.extension.http.internal.request.HttpRequestOperations
METHOD request
AT ENTRY
IF true
DO
  traceln("[MUNIT_LEAK][HTTP-OP] Real http:request reached connector layer." +
    " Thread=" + Thread.currentThread().getName())
ENDRULE


