RULE APACHE_HTTP_EXECUTE
CLASS org.apache.http.impl.execchain.MainClientExec
METHOD execute
AT ENTRY
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=APACHE_HTTP" +
        "\nTARGET=" + $1 +
        "\nREQUEST=" + $2 +
        "\n"
    );
ENDRULE

