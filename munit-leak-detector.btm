##############################################################################
# 4. SFTP CONNECTOR
# Class:  org.mule.extension.sftp.internal.connection.SftpClient
# Source: github.com/mulesoft/mule-sftp-connector (main + master, verified)
# Connector >= 2.0.x uses Apache Mina SSHD; < 2.0.x uses jcraft/JSch.
# All three layers are covered.
##############################################################################

RULE MUNIT_LEAK :: SFTP write via SftpClient.write
CLASS org.mule.extension.sftp.internal.connection.SftpClient
METHOD write
AT ENTRY
IF true
DO
  traceln("[MUNIT_LEAK][SFTP-WRITE] Real SFTP write - mock NOT applied." +
    " Thread=" + Thread.currentThread().getName());
  traceln("[MUNIT_LEAK][SFTP-WRITE] Stack=" +
    java.util.Arrays.toString(Thread.currentThread().getStackTrace()))
ENDRULE

RULE MUNIT_LEAK :: SFTP read via SftpClient.read
CLASS org.mule.extension.sftp.internal.connection.SftpClient
