###############################################################################
# 11. JMS GENERIC
#
# IMPORTANT:
# Detects publish attempts even if actual socket path differs.
###############################################################################

RULE JMS_MESSAGE_PRODUCER_SEND
INTERFACE javax.jms.MessageProducer
METHOD send
AT ENTRY
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=JMS_SEND" +
        "\nCLASS=" + $0.getClass().getName() +
        "\n"
    );
ENDRULE

RULE JMS_CONNECTION_START
INTERFACE javax.jms.Connection
METHOD start
AT ENTRY
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=JMS_CONNECTION_START" +
        "\nCLASS=" + $0.getClass().getName() +
        "\n"
    );
ENDRULE

RULE JMS_CREATE_SESSION
INTERFACE javax.jms.Connection
METHOD createSession
AT ENTRY
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=JMS_CREATE_SESSION" +
        "\n"
    );
ENDRULE

