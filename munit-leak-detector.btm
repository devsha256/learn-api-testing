###############################################################################
# MULE / MUNIT OUTBOUND LEAK DETECTOR
#
# PURPOSE
# -------
# Detect REAL outbound network activity during MUnit execution.
#
# IMPORTANT
# ---------
# This file intentionally avoids fragile Mule internal connector classes.
#
# Why?
# Mule internals differ heavily across:
# - Mule runtime versions
# - connector versions
# - AsyncHttpClient versions
# - Netty/Reactor versions
#
# Stable transport-layer interception is FAR more reliable.
#
# DESIGN
# ------
# Detect outbound activity at:
# - Socket layer
# - NIO layer
# - Netty layer
# - SSL layer
# - URL layer
#
# This catches:
# - Mule HTTP connector leaks
# - JMS broker leaks
# - DB leaks
# - SFTP leaks
# - SMTP leaks
# - AWS SDK leaks
# - Any TCP-based connector leaks
#
###############################################################################

###############################################################################
# 1. CLASSIC SOCKETS
###############################################################################

RULE SOCKET_CONNECT_TIMEOUT
CLASS java.net.Socket
METHOD connect(java.net.SocketAddress,int)
AT ENTRY
BIND
    dest:String = String.valueOf($1);
IF (
    dest != null &&
    !dest.contains("127.0.0.1") &&
    !dest.contains("localhost") &&
    !dest.contains("0:0:0:0:0:0:0:1")
)
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=SOCKET" +
        "\nDEST=" + dest +
        "\nTHREAD=" + Thread.currentThread().getName() +
        "\n"
    );
ENDRULE

RULE SOCKET_CONNECT
CLASS java.net.Socket
METHOD connect(java.net.SocketAddress)
AT ENTRY
BIND
    dest:String = String.valueOf($1);
IF (
    dest != null &&
    !dest.contains("127.0.0.1") &&
    !dest.contains("localhost") &&
    !dest.contains("0:0:0:0:0:0:0:1")
)
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=SOCKET_OVERLOAD" +
        "\nDEST=" + dest +
        "\nTHREAD=" + Thread.currentThread().getName() +
        "\n"
    );
ENDRULE

###############################################################################
# 2. SOCKET IMPLEMENTATION LAYER
#
# IMPORTANT:
# Some runtimes bypass java.net.Socket directly.
###############################################################################

RULE ABSTRACT_SOCKET_CONNECT_1
CLASS java.net.AbstractPlainSocketImpl
METHOD connect(java.lang.String,int)
AT ENTRY
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=ABSTRACT_SOCKET_IMPL" +
        "\nHOST=" + $1 +
        "\nPORT=" + $2 +
        "\n"
    );
ENDRULE

RULE ABSTRACT_SOCKET_CONNECT_2
CLASS java.net.AbstractPlainSocketImpl
METHOD connect(java.net.InetAddress,int)
AT ENTRY
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=ABSTRACT_SOCKET_IMPL_INET" +
        "\nHOST=" + $1 +
        "\nPORT=" + $2 +
        "\n"
    );
ENDRULE

###############################################################################
# 3. NIO SOCKETS
#
# Many modern JMS/HTTP stacks use NIO directly.
###############################################################################

RULE NIO_SOCKET_CONNECT
CLASS sun.nio.ch.SocketChannelImpl
METHOD connect
AT ENTRY
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=NIO_SOCKET" +
        "\nDEST=" + $1 +
        "\nTHREAD=" + Thread.currentThread().getName() +
        "\n"
    );
ENDRULE

RULE NIO_SOCKET_FINISH_CONNECT
CLASS sun.nio.ch.SocketChannelImpl
METHOD finishConnect
AT ENTRY
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=NIO_FINISH_CONNECT" +
        "\nTHREAD=" + Thread.currentThread().getName() +
        "\n"
    );
ENDRULE

###############################################################################
# 4. NETTY
#
# CRITICAL:
# Mule HTTP connector frequently uses Netty internally.
###############################################################################

RULE NETTY_BOOTSTRAP_CONNECT
CLASS io.netty.bootstrap.Bootstrap
METHOD connect
AT ENTRY
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=NETTY_BOOTSTRAP" +
        "\nDEST=" + $1 +
        "\nTHREAD=" + Thread.currentThread().getName() +
        "\n"
    );
ENDRULE

RULE NETTY_NIO_SOCKET_CONNECT
CLASS io.netty.channel.socket.nio.NioSocketChannel
METHOD doConnect
AT ENTRY
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=NETTY_NIO_SOCKET" +
        "\nREMOTE=" + $1 +
        "\nLOCAL=" + $2 +
        "\nTHREAD=" + Thread.currentThread().getName() +
        "\n"
    );
ENDRULE

RULE NETTY_CHANNEL_CONNECT
CLASS io.netty.channel.AbstractChannel
METHOD connect
AT ENTRY
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=NETTY_CHANNEL" +
        "\nDEST=" + $1 +
        "\n"
    );
ENDRULE

###############################################################################
# 5. REACTOR NETTY
#
# Used in newer async stacks.
###############################################################################

RULE REACTOR_NETTY_CONNECT
CLASS reactor.netty.transport.TransportConnector
METHOD connect
AT ENTRY
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=REACTOR_NETTY" +
        "\nDEST=" + $1 +
        "\n"
    );
ENDRULE

###############################################################################
# 6. SSL / TLS
#
# Useful for JMS SSL brokers and HTTPS leaks.
###############################################################################

RULE SSL_SOCKET_HANDSHAKE
CLASS javax.net.ssl.SSLSocket
METHOD startHandshake
AT ENTRY
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=SSL_HANDSHAKE" +
        "\nTHREAD=" + Thread.currentThread().getName() +
        "\n"
    );
ENDRULE

RULE SSL_ENGINE_WRAP
CLASS javax.net.ssl.SSLEngine
METHOD wrap
AT ENTRY
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=SSL_ENGINE_WRAP" +
        "\n"
    );
ENDRULE

RULE SSL_ENGINE_UNWRAP
CLASS javax.net.ssl.SSLEngine
METHOD unwrap
AT ENTRY
DO
    traceln(
        "\n[OUTBOUND-LEAK]" +
        "\nTYPE=SSL_ENGINE_UNWRAP" +
        "\n"
    );
ENDRULE

